{
    "name": "ucan-lab/laravel-blink-logger",
    "description": "Comprehensive Logging Tool for Laravel.",
    "keywords": [
        "php",
        "laravel",
        "logger"
    ],
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "LaravelBlinkLogger\\": "src/"
        }
    },
    "authors": [
        {
            "name": "ucan-lab",
            "email": "35098175+ucan-lab@users.noreply.github.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "laravel/framework": "^11.0|^12.0|^13.0"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        },
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "extra": {
        "laravel": {
            "providers": [
                "LaravelBlinkLogger\\Providers\\LaravelBlinkLoggerServiceProvider"
            ]
        }
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "1.29.*",
        "mockery/mockery": "^1.6",
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "pestphp/pest": "^3.0"
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "pest",
        "analyse": "phpstan analyse"
    }
}
